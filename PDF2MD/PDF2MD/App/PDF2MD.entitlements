<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Run inside the App Sandbox. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Read/write access to the PDFs and output folder the user chooses.
	     read-write also covers reading, so no separate read-only key is needed. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- Outbound network access for the optional AI conversion engine.
	     The local PDFKit engine makes no network calls. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
